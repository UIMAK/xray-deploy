{
    "listen": "{{LISTEN}}",
    "port": {{PORT}},
    "protocol": "vless",
    "tag": "{{TAG}}",
    "settings": {
        "clients": [
            {
                "id": "{{UUID}}",
                "flow": "{{FLOW}}"
            }
        ],
        "decryption": "{{DECRYPTION}}"
    },
    "streamSettings": {
        "network": "raw"
    },
    "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"],
        "routeOnly": true
    }
}
